      <div className="pointer-events-none fixed inset-0 -z-30 bg-[linear-gradient(115deg,transparent_0%,rgba(255,255,255,0.025)_43%,rgba(215,176,106,0.055)_50%,rgba(255,255,255,0.025)_57%,transparent_100%)] opacity-60" />

      <motion.div
        className="pointer-events-none fixed left-1/2 top-[42%] -z-20 h-[98vmin] w-[98vmin] -translate-x-1/2 -translate-y-1/2 rounded-full border border-[#d7b06a]/10"
        animate={shouldReduceMotion ? undefined : {rotate: 360}}
        transition={{duration: 60, repeat: Infinity, ease: "linear"}}
      />
      <motion.div
        className="pointer-events-none fixed left-1/2 top-[42%] -z-20 h-[72vmin] w-[72vmin] -translate-x-1/2 -translate-y-1/2 rounded-full border border-[#d7b06a]/10"
