function getLang(): Lang {
  if (typeof document === "undefined") return "en"

  const htmlLang = document.documentElement.getAttribute("lang")?.toLowerCase() || ""
  const htmlDir = document.documentElement.getAttribute("dir")?.toLowerCase() || ""
  const bodyDir = document.body?.getAttribute("dir")?.toLowerCase() || ""

  if (htmlLang.startsWith("fa") || htmlDir === "rtl" || bodyDir === "rtl") return "fa"
  return "en"
}

function iconFor(name: string) {
  if (name === "palette") return Palette
  if (name === "image") return ImageIcon
  if (name === "wand") return Wand2
  if (name === "camera") return Camera
  return Layers3
}

export default function PremiumHomePage() {
  const shouldReduceMotion = useReducedMotion()
  const [lang, setLang] = useState<Lang>("en")
  const [cursor, setCursor] = useState({x: 50, y: 36})

  useEffect(() => {
    const updateLang = () => setLang(getLang())
    updateLang()

    const observer = new MutationObserver(updateLang)

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["lang", "dir"],
    })

    if (document.body) {
      observer.observe(document.body, {
        attributes: true,
        attributeFilter: ["dir", "lang"],
      })
    }

    return () => observer.disconnect()
  }, [])

  const isFa = lang === "fa"
  const t = copy[lang]

  const particles = useMemo(
    () =>
      Array.from({length: 74}, (_, index) => ({
        id: index,
        left: `${2 + ((index * 37) % 96)}%`,
        top: `${4 + ((index * 53) % 88)}%`,
        size: index % 9 === 0 ? 2.45 : index % 4 === 0 ? 1.65 : 1.05,
        delay: (index % 17) * 0.07,
        opacity: index % 7 === 0 ? 0.5 : 0.22,
      })),
    []
  )

  const handlePointerMove = (event: PointerEvent<HTMLElement>) => {
    const rect = event.currentTarget.getBoundingClientRect()
    setCursor({
      x: ((event.clientX - rect.left) / rect.width) * 100,
      y: ((event.clientY - rect.top) / rect.height) * 100,
    })
  }

  const spotlightStyle = {
    "--mx": `${cursor.x}%`,
    "--my": `${cursor.y}%`,
  } as CSSProperties

  return (
    <main
      dir={isFa ? "rtl" : "ltr"}
      onPointerMove={handlePointerMove}
      className="relative isolate min-h-screen overflow-hidden bg-[#020202] text-white"
      style={spotlightStyle}
    >
