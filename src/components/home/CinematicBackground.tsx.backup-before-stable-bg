"use client"

import {motion, useReducedMotion} from "framer-motion"
import {useEffect, useMemo, useRef} from "react"

const easeDust = "easeInOut"

export default function CinematicBackground() {
  const shouldReduceMotion = useReducedMotion()
  const rootRef = useRef<HTMLDivElement | null>(null)
  const pointerRef = useRef({x: 0, y: 0})
  const haloRef = useRef({x: 0, y: 0})
  const dustRef = useRef({x: 0, y: 0})
  const rafRef = useRef<number | null>(null)

  const goldDust = useMemo(
    () =>
      Array.from({length: 210}, (_, index) => {
        const large = index % 13 === 0
        const medium = index % 5 === 0

        return {
          id: index,
          left: `${1 + ((index * 37) % 98)}%`,
          top: `${3 + ((index * 61) % 92)}%`,
          size: large ? 2.9 : medium ? 1.9 : 1.15,
          opacity: large ? 0.72 : medium ? 0.48 : 0.31,
          delay: (index % 24) * 0.085,
          duration: 4.8 + (index % 7) * 0.55,
          drift: large ? 20 : medium ? 14 : 9,
        }
      }),
    []
  )

  const nearDust = useMemo(
    () =>
      Array.from({length: 28}, (_, index) => ({
        id: index,
        angle: (index / 28) * Math.PI * 2,
        distance: 38 + (index % 7) * 18,
        size: index % 5 === 0 ? 2.25 : 1.25,
        delay: index * 0.045,
      })),
    []
  )

  useEffect(() => {
    const element = rootRef.current

    if (!element) return

    const writeVars = () => {
      element.style.setProperty("--mx", `${pointerRef.current.x}px`)
      element.style.setProperty("--my", `${pointerRef.current.y}px`)
      element.style.setProperty("--hx", `${haloRef.current.x}px`)
      element.style.setProperty("--hy", `${haloRef.current.y}px`)
      element.style.setProperty("--dx", `${dustRef.current.x}px`)
      element.style.setProperty("--dy", `${dustRef.current.y}px`)
    }

    const setInitialPosition = () => {
      const initial = {
        x: Math.round(window.innerWidth * 0.52),
        y: Math.round(window.innerHeight * 0.38),
      }

      pointerRef.current = initial
      haloRef.current = initial
      dustRef.current = initial
      writeVars()
    }

    const handlePointerMove = (event: PointerEvent) => {
      pointerRef.current = {
        x: Math.round(event.clientX),
        y: Math.round(event.clientY),
      }

      element.style.setProperty("--mx", `${pointerRef.current.x}px`)
      element.style.setProperty("--my", `${pointerRef.current.y}px`)
    }

    const frame = () => {
      haloRef.current = {
        x: haloRef.current.x + (pointerRef.current.x - haloRef.current.x) * 0.11,
        y: haloRef.current.y + (pointerRef.current.y - haloRef.current.y) * 0.11,
      }

      dustRef.current = {
        x: dustRef.current.x + (haloRef.current.x - dustRef.current.x) * 0.055,
        y: dustRef.current.y + (haloRef.current.y - dustRef.current.y) * 0.055,
      }

      writeVars()
      rafRef.current = window.requestAnimationFrame(frame)
    }

    setInitialPosition()
    window.addEventListener("pointermove", handlePointerMove, {passive: true})
    window.addEventListener("resize", setInitialPosition)

    rafRef.current = window.requestAnimationFrame(frame)

    return () => {
      window.removeEventListener("pointermove", handlePointerMove)
      window.removeEventListener("resize", setInitialPosition)

      if (rafRef.current !== null) {
        window.cancelAnimationFrame(rafRef.current)
      }
    }
  }, [])

  return (
    <div
      ref={rootRef}
      aria-hidden="true"
      className="pointer-events-none fixed inset-0 -z-40 overflow-hidden bg-[#020202]"
      style={{
        "--mx": "52vw",
        "--my": "38vh",
        "--hx": "52vw",
        "--hy": "38vh",
        "--dx": "52vw",
        "--dy": "38vh",
      } as React.CSSProperties}
    >
      <div className="absolute inset-0 bg-[radial-gradient(circle_at_var(--hx)_var(--hy),rgba(255,229,178,0.29),transparent_25%),radial-gradient(circle_at_50%_12%,rgba(255,244,220,0.18),transparent_34%),radial-gradient(circle_at_13%_18%,rgba(214,146,67,0.28),transparent_43%),radial-gradient(circle_at_87%_74%,rgba(114,63,24,0.25),transparent_42%),linear-gradient(180deg,#050505_0%,#080705_42%,#020202_100%)]" />

      <div
        className="absolute left-0 top-0 h-[7rem] w-[7rem] rounded-full bg-[radial-gradient(circle,rgba(255,249,235,0.98)_0%,rgba(255,214,139,0.55)_18%,rgba(215,176,106,0.18)_48%,transparent_72%)] blur-lg mix-blend-screen will-change-transform"
        style={{transform: "translate3d(calc(var(--mx) - 3.5rem), calc(var(--my) - 3.5rem), 0)"}}
      />

      <div
        className="absolute left-0 top-0 h-[40rem] w-[40rem] rounded-full bg-[radial-gradient(circle,rgba(255,232,185,0.28)_0%,rgba(215,176,106,0.18)_30%,rgba(215,176,106,0.06)_56%,transparent_74%)] blur-2xl mix-blend-screen will-change-transform"
        style={{transform: "translate3d(calc(var(--hx) - 20rem), calc(var(--hy) - 20rem), 0)"}}
      />

      <div
        className="absolute left-0 top-0 h-[25rem] w-[25rem] rounded-full bg-[radial-gradient(circle,rgba(255,255,255,0.1)_0%,rgba(215,176,106,0.12)_32%,transparent_72%)] blur-xl mix-blend-screen will-change-transform"
        style={{transform: "translate3d(calc(var(--dx) - 12.5rem), calc(var(--dy) - 12.5rem), 0)"}}
      />

      {!shouldReduceMotion &&
        nearDust.map((item) => (
          <motion.span
            key={item.id}
            className="absolute left-0 top-0 rounded-full bg-[#ffe2a4] mix-blend-screen shadow-[0_0_28px_rgba(215,176,106,0.8)] will-change-transform"
            style={{
              width: item.size,
              height: item.size,
              transform: `translate3d(calc(var(--dx) + ${Math.cos(item.angle) * item.distance}px), calc(var(--dy) + ${Math.sin(item.angle) * item.distance}px), 0)`,
            }}
            animate={{
              opacity: [0.1, 0.85, 0.18],
              scale: [0.7, 1.35, 0.8],
            }}
            transition={{
              duration: 2.7,
              delay: item.delay,
              repeat: Infinity,
              ease: easeDust,
            }}
          />
        ))}

      <motion.div
        className="absolute left-[5%] top-[6%] h-[34rem] w-[34rem] rounded-full bg-[#d7b06a]/16 blur-[98px]"
        animate={shouldReduceMotion ? undefined : {x: [0, 42, -18, 0], y: [0, 24, 48, 0], scale: [1, 1.12, 0.96, 1]}}
        transition={{duration: 16, repeat: Infinity, ease: "easeInOut"}}
      />

      <motion.div
        className="absolute right-[2%] top-[28%] h-[30rem] w-[30rem] rounded-full bg-[#a76523]/18 blur-[100px]"
        animate={shouldReduceMotion ? undefined : {x: [0, -36, 24, 0], y: [0, 40, -18, 0], scale: [1, 0.92, 1.16, 1]}}
        transition={{duration: 18, repeat: Infinity, ease: "easeInOut"}}
      />

      <motion.div
        className="absolute bottom-[-12%] left-1/2 h-[34rem] w-[64rem] -translate-x-1/2 rounded-[999px] bg-[#d7b06a]/16 blur-[94px]"
        animate={shouldReduceMotion ? undefined : {scaleX: [1, 1.12, 0.96, 1], opacity: [0.42, 0.78, 0.5, 0.42]}}
        transition={{duration: 12, repeat: Infinity, ease: "easeInOut"}}
      />

      <div className="absolute inset-0 opacity-[0.08] [background-image:linear-gradient(rgba(255,255,255,0.9)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.9)_1px,transparent_1px)] [background-size:98px_98px] [mask-image:radial-gradient(ellipse_at_center,black_0%,black_40%,transparent_76%)]" />

      <div className="absolute inset-0 opacity-[0.13] [background-image:linear-gradient(30deg,rgba(255,255,255,0.055)_1px,transparent_1px)] [background-size:180px_180px] [mask-image:radial-gradient(ellipse_at_center,black_0%,transparent_72%)]" />

      <motion.div
        className="absolute left-[-20%] top-[18%] h-[22rem] w-[140vw] -rotate-[16deg] bg-[linear-gradient(90deg,transparent,rgba(215,176,106,0.18),rgba(255,242,210,0.22),rgba(215,176,106,0.14),transparent)] blur-2xl"
        animate={shouldReduceMotion ? undefined : {x: ["-8%", "10%", "-8%"], opacity: [0.24, 0.74, 0.24]}}
        transition={{duration: 9, repeat: Infinity, ease: "easeInOut"}}
      />

      <motion.div
        className="absolute right-[-24%] bottom-[14%] h-[18rem] w-[120vw] rotate-[15deg] bg-[linear-gradient(90deg,transparent,rgba(255,255,255,0.04),rgba(215,176,106,0.14),transparent)] blur-2xl"
        animate={shouldReduceMotion ? undefined : {x: ["8%", "-8%", "8%"], opacity: [0.14, 0.46, 0.14]}}
        transition={{duration: 13, repeat: Infinity, ease: "easeInOut"}}
      />

      {!shouldReduceMotion &&
        goldDust.map((item) => (
          <motion.span
            key={item.id}
            className="absolute rounded-full bg-[#f8d88d] mix-blend-screen"
            style={{
              left: item.left,
              top: item.top,
              width: item.size,
              height: item.size,
              boxShadow: "0 0 30px rgba(215,176,106,0.72)",
            }}
            initial={{opacity: 0, scale: 0.65}}
            animate={{
              opacity: [0, item.opacity, item.opacity * 0.55, 0],
              scale: [0.7, 1.45, 0.92, 0.7],
              y: [-item.drift, item.drift, -item.drift],
              x: [0, item.drift * 0.45, 0],
            }}
            transition={{
              duration: item.duration,
              delay: item.delay,
              repeat: Infinity,
              ease: "easeInOut",
            }}
          />
        ))}

      <motion.div
        className="absolute left-1/2 top-[42%] h-[108vmin] w-[108vmin] -translate-x-1/2 -translate-y-1/2 rounded-full border border-[#d7b06a]/10"
        animate={shouldReduceMotion ? undefined : {rotate: 360}}
        transition={{duration: 62, repeat: Infinity, ease: "linear"}}
      />

      <motion.div
        className="absolute left-1/2 top-[42%] h-[74vmin] w-[74vmin] -translate-x-1/2 -translate-y-1/2 rounded-full border border-[#d7b06a]/10"
        animate={shouldReduceMotion ? undefined : {rotate: -360}}
        transition={{duration: 48, repeat: Infinity, ease: "linear"}}
      />

      <div
        className="absolute inset-0 opacity-[0.07] mix-blend-overlay"
        style={{
          backgroundImage:
            "repeating-radial-gradient(circle at 30% 40%, rgba(255,255,255,0.6) 0 0.5px, transparent 0.5px 3px)",
        }}
      />

      <div className="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-black via-black/60 to-transparent" />
      <div className="absolute inset-x-0 bottom-0 h-44 bg-gradient-to-t from-black via-black/70 to-transparent" />
    </div>
  )
}