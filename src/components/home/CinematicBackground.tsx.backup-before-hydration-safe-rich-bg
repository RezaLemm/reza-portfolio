"use client"

import {motion, useReducedMotion} from "framer-motion"
import {useEffect, useMemo, useRef} from "react"
import type {CSSProperties} from "react"

export default function CinematicBackground() {
  const shouldReduceMotion = useReducedMotion()
  const rootRef = useRef<HTMLDivElement | null>(null)
  const pointerRef = useRef({x: 0, y: 0})
  const haloRef = useRef({x: 0, y: 0})
  const dustHaloRef = useRef({x: 0, y: 0})
  const rafRef = useRef<number | null>(null)

  const goldDust = useMemo(
    () =>
      Array.from({length: 128}, (_, index) => {
        const hero = index % 17 === 0
        const medium = index % 5 === 0

        return {
          id: index,
          left: `${2 + ((index * 37) % 96)}%`,
          top: `${4 + ((index * 61) % 88)}%`,
          size: hero ? 3.2 : medium ? 2 : 1.15,
          opacity: hero ? 0.82 : medium ? 0.55 : 0.34,
          delay: (index % 26) * 0.08,
          duration: 5.4 + (index % 7) * 0.5,
          drift: hero ? 24 : medium ? 16 : 10,
        }
      }),
    []
  )

  const cursorDust = useMemo(
    () =>
      Array.from({length: 18}, (_, index) => ({
        id: index,
        angle: (index / 18) * Math.PI * 2,
        distance: 34 + (index % 6) * 15,
        size: index % 4 === 0 ? 2.2 : 1.15,
        delay: index * 0.06,
      })),
    []
  )

  useEffect(() => {
    const element = rootRef.current

    if (!element) return

    const writeVars = () => {
      element.style.setProperty("--mx", `${pointerRef.current.x}px`)
      element.style.setProperty("--my", `${pointerRef.current.y}px`)
      element.style.setProperty("--hx", `${haloRef.current.x}px`)
      element.style.setProperty("--hy", `${haloRef.current.y}px`)
      element.style.setProperty("--dx", `${dustHaloRef.current.x}px`)
      element.style.setProperty("--dy", `${dustHaloRef.current.y}px`)
    }

    const setInitialPosition = () => {
      const initial = {
        x: Math.round(window.innerWidth * 0.52),
        y: Math.round(window.innerHeight * 0.38),
      }

      pointerRef.current = initial
      haloRef.current = initial
      dustHaloRef.current = initial
      writeVars()
    }

    const handlePointerMove = (event: PointerEvent) => {
      pointerRef.current = {
        x: Math.round(event.clientX),
        y: Math.round(event.clientY),
      }

      element.style.setProperty("--mx", `${pointerRef.current.x}px`)
      element.style.setProperty("--my", `${pointerRef.current.y}px`)
    }

    const frame = () => {
      haloRef.current = {
        x: haloRef.current.x + (pointerRef.current.x - haloRef.current.x) * 0.11,
        y: haloRef.current.y + (pointerRef.current.y - haloRef.current.y) * 0.11,
      }

      dustHaloRef.current = {
        x: dustHaloRef.current.x + (haloRef.current.x - dustHaloRef.current.x) * 0.06,
        y: dustHaloRef.current.y + (haloRef.current.y - dustHaloRef.current.y) * 0.06,
      }

      writeVars()
      rafRef.current = window.requestAnimationFrame(frame)
    }

    setInitialPosition()
    window.addEventListener("pointermove", handlePointerMove, {passive: true})
    window.addEventListener("resize", setInitialPosition)
    rafRef.current = window.requestAnimationFrame(frame)

    return () => {
      window.removeEventListener("pointermove", handlePointerMove)
      window.removeEventListener("resize", setInitialPosition)

      if (rafRef.current !== null) {
        window.cancelAnimationFrame(rafRef.current)
      }
    }
  }, [])

  return (
    <div
      ref={rootRef}
      aria-hidden="true"
      className="pointer-events-none fixed inset-0 -z-10 overflow-hidden bg-[#020202]"
      style={
        {
          "--mx": "52vw",
          "--my": "38vh",
          "--hx": "52vw",
          "--hy": "38vh",
          "--dx": "52vw",
          "--dy": "38vh",
        } as CSSProperties
      }
    >
      <div className="absolute inset-0 bg-[radial-gradient(circle_at_var(--hx)_var(--hy),rgba(255,229,178,0.28),transparent_25%),radial-gradient(circle_at_50%_12%,rgba(255,244,220,0.16),transparent_34%),radial-gradient(circle_at_13%_18%,rgba(214,146,67,0.24),transparent_43%),radial-gradient(circle_at_87%_74%,rgba(114,63,24,0.22),transparent_42%),linear-gradient(180deg,#050505_0%,#080705_42%,#020202_100%)]" />

      <div
        className="absolute left-0 top-0 h-[7rem] w-[7rem] rounded-full bg-[radial-gradient(circle,rgba(255,249,235,0.94)_0%,rgba(255,214,139,0.48)_18%,rgba(215,176,106,0.16)_48%,transparent_72%)] blur-lg mix-blend-screen will-change-transform"
        style={{transform: "translate3d(calc(var(--mx) - 3.5rem), calc(var(--my) - 3.5rem), 0)"}}
      />

      <div
        className="absolute left-0 top-0 h-[38rem] w-[38rem] rounded-full bg-[radial-gradient(circle,rgba(255,232,185,0.24)_0%,rgba(215,176,106,0.15)_30%,rgba(215,176,106,0.05)_56%,transparent_74%)] blur-2xl will-change-transform"
        style={{transform: "translate3d(calc(var(--hx) - 19rem), calc(var(--hy) - 19rem), 0)"}}
      />

      <div
        className="absolute left-0 top-0 h-[24rem] w-[24rem] rounded-full bg-[radial-gradient(circle,rgba(255,255,255,0.08)_0%,rgba(215,176,106,0.11)_32%,transparent_72%)] blur-xl will-change-transform"
        style={{transform: "translate3d(calc(var(--dx) - 12rem), calc(var(--dy) - 12rem), 0)"}}
      />

      {!shouldReduceMotion &&
        cursorDust.map((item) => (
          <motion.span
            key={item.id}
            className="absolute left-0 top-0 rounded-full bg-[#ffe0a0] shadow-[0_0_22px_rgba(215,176,106,0.72)] will-change-transform"
            style={{
              width: item.size,
              height: item.size,
              transform: `translate3d(calc(var(--dx) + ${Math.cos(item.angle) * item.distance}px), calc(var(--dy) + ${Math.sin(item.angle) * item.distance}px), 0)`,
            }}
            animate={{
              opacity: [0.12, 0.75, 0.18],
              scale: [0.72, 1.28, 0.82],
            }}
            transition={{
              duration: 3.2,
              delay: item.delay,
              repeat: Infinity,
              ease: "easeInOut",
            }}
          />
        ))}

      <motion.div
        className="absolute left-[5%] top-[6%] h-[32rem] w-[32rem] rounded-full bg-[#d7b06a]/14 blur-[96px]"
        animate={shouldReduceMotion ? undefined : {x: [0, 38, -16, 0], y: [0, 22, 42, 0], scale: [1, 1.08, 0.98, 1]}}
        transition={{duration: 18, repeat: Infinity, ease: "easeInOut"}}
      />

      <motion.div
        className="absolute right-[2%] top-[28%] h-[28rem] w-[28rem] rounded-full bg-[#a76523]/14 blur-[98px]"
        animate={shouldReduceMotion ? undefined : {x: [0, -30, 18, 0], y: [0, 34, -14, 0], scale: [1, 0.96, 1.1, 1]}}
        transition={{duration: 20, repeat: Infinity, ease: "easeInOut"}}
      />

      <motion.div
        className="absolute bottom-[-12%] left-1/2 h-[32rem] w-[60rem] -translate-x-1/2 rounded-[999px] bg-[#d7b06a]/13 blur-[94px]"
        animate={shouldReduceMotion ? undefined : {scaleX: [1, 1.08, 0.98, 1], opacity: [0.45, 0.65, 0.5, 0.45]}}
        transition={{duration: 14, repeat: Infinity, ease: "easeInOut"}}
      />

      <div className="absolute inset-0 opacity-[0.075] [background-image:linear-gradient(rgba(255,255,255,0.9)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.9)_1px,transparent_1px)] [background-size:104px_104px] [mask-image:radial-gradient(ellipse_at_center,black_0%,black_40%,transparent_76%)]" />

      <div className="absolute inset-0 opacity-[0.1] [background-image:linear-gradient(30deg,rgba(255,255,255,0.045)_1px,transparent_1px)] [background-size:190px_190px] [mask-image:radial-gradient(ellipse_at_center,black_0%,transparent_72%)]" />

      <motion.div
        className="absolute left-[-20%] top-[18%] h-[20rem] w-[140vw] -rotate-[16deg] bg-[linear-gradient(90deg,transparent,rgba(215,176,106,0.15),rgba(255,242,210,0.18),rgba(215,176,106,0.12),transparent)] blur-2xl"
        animate={shouldReduceMotion ? undefined : {x: ["-8%", "10%", "-8%"], opacity: [0.26, 0.55, 0.26]}}
        transition={{duration: 12, repeat: Infinity, ease: "easeInOut"}}
      />

      {!shouldReduceMotion &&
        goldDust.map((item) => (
          <motion.span
            key={item.id}
            className="absolute rounded-full bg-[#f8d88d]"
            style={{
              left: item.left,
              top: item.top,
              width: item.size,
              height: item.size,
              boxShadow: "0 0 26px rgba(215,176,106,0.66)",
            }}
            initial={{opacity: 0, scale: 0.65}}
            animate={{
              opacity: [0, item.opacity, item.opacity * 0.58, 0],
              scale: [0.7, 1.32, 0.92, 0.7],
              y: [-item.drift, item.drift, -item.drift],
              x: [0, item.drift * 0.36, 0],
            }}
            transition={{
              duration: item.duration,
              delay: item.delay,
              repeat: Infinity,
              ease: "easeInOut",
            }}
          />
        ))}

      <div
        className="absolute inset-0 opacity-[0.045] mix-blend-overlay"
        style={{
          backgroundImage:
            "repeating-radial-gradient(circle at 30% 40%, rgba(255,255,255,0.6) 0 0.5px, transparent 0.5px 3px)",
        }}
      />

      <div className="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-black via-black/60 to-transparent" />
      <div className="absolute inset-x-0 bottom-0 h-44 bg-gradient-to-t from-black via-black/70 to-transparent" />
    </div>
  )
}