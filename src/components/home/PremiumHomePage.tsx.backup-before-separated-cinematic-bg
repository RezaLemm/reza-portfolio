function getLang(): Lang {
  if (typeof document === "undefined") return "en"

  const htmlLang = document.documentElement.getAttribute("lang")?.toLowerCase() || ""
  const htmlDir = document.documentElement.getAttribute("dir")?.toLowerCase() || ""
  const bodyDir = document.body?.getAttribute("dir")?.toLowerCase() || ""

  if (htmlLang.startsWith("fa") || htmlDir === "rtl" || bodyDir === "rtl") return "fa"
  return "en"
}

export default function PremiumHomePage() {
  const shouldReduceMotion = useReducedMotion()
  const [lang, setLang] = useState<Lang>("en")
  const mainRef = useRef<HTMLElement | null>(null)
  const pointerRef = useRef({x: 0, y: 0})
  const smoothRef = useRef({x: 0, y: 0})
  const dustRef = useRef({x: 0, y: 0})
  const rafRef = useRef<number | null>(null)

  useEffect(() => {
    const updateLang = () => setLang(getLang())
    updateLang()

    const observer = new MutationObserver(updateLang)

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["lang", "dir"],
    })

    if (document.body) {
      observer.observe(document.body, {
        attributes: true,
        attributeFilter: ["dir", "lang"],
      })
    }

    return () => observer.disconnect()
  }, [])

  useEffect(() => {
    const element = mainRef.current

    if (!element) return

    const writeVars = () => {
      element.style.setProperty("--mx", `${pointerRef.current.x}px`)
      element.style.setProperty("--my", `${pointerRef.current.y}px`)
      element.style.setProperty("--sx", `${smoothRef.current.x}px`)
      element.style.setProperty("--sy", `${smoothRef.current.y}px`)
    }

    const setInitialPosition = () => {
      const initial = {
        x: Math.round(window.innerWidth * 0.5),
        y: Math.round(window.innerHeight * 0.38),
      }

      pointerRef.current = initial
      smoothRef.current = initial
      writeVars()
    }

    const smoothCursorFrame = () => {
      smoothRef.current = {
        x: smoothRef.current.x + (pointerRef.current.x - smoothRef.current.x) * 0.115,
        y: smoothRef.current.y + (pointerRef.current.y - smoothRef.current.y) * 0.115,
      }

      writeVars()
      rafRef.current = window.requestAnimationFrame(smoothCursorFrame)
    }

    setInitialPosition()
    window.addEventListener("resize", setInitialPosition)
    rafRef.current = window.requestAnimationFrame(smoothCursorFrame)

    return () => {
      window.removeEventListener("resize", setInitialPosition)

      if (rafRef.current !== null) {
        window.cancelAnimationFrame(rafRef.current)
      }
    }
  }, [])
  useEffect(() => {
    const element = mainRef.current

    if (!element) return

    const writeVars = () => {
      element.style.setProperty("--mx", `${pointerRef.current.x}px`)
      element.style.setProperty("--my", `${pointerRef.current.y}px`)
      element.style.setProperty("--sx", `${smoothRef.current.x}px`)
      element.style.setProperty("--sy", `${smoothRef.current.y}px`)
      element.style.setProperty("--dx", `${dustRef.current.x}px`)
      element.style.setProperty("--dy", `${dustRef.current.y}px`)
    }

    const setInitialPosition = () => {
      const initial = {
        x: Math.round(window.innerWidth * 0.5),
        y: Math.round(window.innerHeight * 0.38),
      }

      pointerRef.current = initial
      smoothRef.current = initial
      dustRef.current = initial
      writeVars()
    }

    const goldDustEngineFrame = () => {
      smoothRef.current = {
        x: smoothRef.current.x + (pointerRef.current.x - smoothRef.current.x) * 0.105,
        y: smoothRef.current.y + (pointerRef.current.y - smoothRef.current.y) * 0.105,
      }

      dustRef.current = {
        x: dustRef.current.x + (smoothRef.current.x - dustRef.current.x) * 0.055,
        y: dustRef.current.y + (smoothRef.current.y - dustRef.current.y) * 0.055,
      }

      writeVars()
      rafRef.current = window.requestAnimationFrame(goldDustEngineFrame)
    }

    setInitialPosition()
    window.addEventListener("resize", setInitialPosition)
    rafRef.current = window.requestAnimationFrame(goldDustEngineFrame)

    return () => {
